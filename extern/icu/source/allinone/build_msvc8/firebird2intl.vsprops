<?xml version="1.0" encoding="Windows-1252"?>
<VisualStudioPropertySheet
    ProjectType="Visual C++"
    Version="8.00"
    Name="firebird2intl"
    OutputDirectory="$(SolutionDir)..\..\..\..\..\Temp\vs2005\$(PlatformName)\$(ConfigurationName)\icu\bin\"
    IntermediateDirectory="$(SolutionDir)..\..\..\..\..\Temp\vs2005\$(PlatformName)\$(ConfigurationName)\icu\obj\$(ProjectName)\"
    >
    <Tool
        Name="VCCLCompilerTool"
        StringPooling="true"
        EnableFunctionLevelLinking="false"
        DisableLanguageExtensions="true"
        WarningLevel="3"
        DebugInformationFormat="3"
        PreprocessorDefinitions="_CRT_SECURE_NO_WARNINGS"
    />
    <Tool
        Name="VCLinkerTool"
        GenerateDebugInformation="true"
    />
    <UserMacro
        Name="ICU_OUT_BIN_DIR"
        Value="$(SolutionDir)..\..\..\$(PlatformName)\$(ConfigurationName)\bin\"
    />
    <UserMacro
        Name="ICU_OUT_LIB_DIR"
        Value="$(SolutionDir)..\..\..\$(PlatformName)\$(ConfigurationName)\lib\"
    />
    <UserMacro
        Name="ICU_ROOT_TMP_DIR"
        Value="$(SolutionDir)..\..\..\..\..\Temp\vs2005\$(PlatformName)\$(ConfigurationName)\icu\"
    />
</VisualStudioPropertySheet>
