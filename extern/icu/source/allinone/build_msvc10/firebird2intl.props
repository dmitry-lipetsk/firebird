<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <_ProjectFileVersion>10.0.30319.1</_ProjectFileVersion>
    <ICU_OUT_BIN_DIR>$(SolutionDir)..\..\..\$(Platform)\$(Configuration)\bin\</ICU_OUT_BIN_DIR>
    <ICU_OUT_LIB_DIR>$(SolutionDir)..\..\..\$(Platform)\$(Configuration)\lib\</ICU_OUT_LIB_DIR>
    <OutDir>$(SolutionDir)..\..\..\..\..\Temp\vs2010\$(PlatformName)\$(Configuration)\icu\bin\</OutDir>
    <IntDir>$(SolutionDir)..\..\..\..\..\Temp\vs2010\$(PlatformName)\$(Configuration)\icu\obj\$(ProjectName)\</IntDir>
    <LinkIncremental>false</LinkIncremental>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <FunctionLevelLinking>false</FunctionLevelLinking>
      <DisableLanguageExtensions>true</DisableLanguageExtensions>
      <WarningLevel>Level3</WarningLevel>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
      <PreprocessorDefinitions>_CRT_SECURE_NO_WARNINGS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <GenerateDebugInformation>true</GenerateDebugInformation>
    </Link>
  </ItemDefinitionGroup>
</Project>